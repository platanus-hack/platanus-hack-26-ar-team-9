# ── Requeridas ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Conexión a Postgres con los artículos scrapeados.
# Con docker-compose esto se setea automáticamente al container local.
# Para dev local apuntá a tu instancia: postgresql://user:pass@host:5432/dbname
SCRAPER_DB_URL=postgresql://postgres:hackaton@localhost:5432/scraper

# ── Opcionales (sobreescriben config.toml) ────────────────────
# MAX_WORKERS_AXIOMA=4
# MAX_WORKERS_TOPICS=10

# ── Solo necesaria si usás fetch_ar_news.py (ingestor legacy) ─
# GROQ_API_KEY=gsk_...
